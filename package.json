{
  "name": "playwright_demoproject",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test:master": "playwright test --grep @master",
    "test:sanity": "playwright test --grep @sanity",
    "test:regression": "playwright test --grep @regression",
    "test:master:allBrowsers": "playwright test --project=chromium --project=firefox --project=webkit --grep @master",
    "test:master:chromium": "playwright test --project=chromium --grep @master",
    "test:clean": "rimraf allure-results",
    "allure:report": "allure generate allure-results --clean -o allure-report",
    "allure:serve": "allure serve allure-results",
    "test:flaky": "npx playwright test --project=chromium --repeat-each=5",
    "test:chrome": "npx playwright test --project=chrome-registration --project=chrome-login --project=chrome-addProductTowishlist --project=chrome-addToCart --project=chrome-forgotPassword --project=chrome-logout --project=chrome-removeProductFromWishlist --project=chrome-search --project=chrome-subscribeToNewsletter --project=chrome-change-password",
    "test:firefox": "npx playwright test --project=firefox-registration --project=firefox-login --project=firefox-addProductTowishlist --project=firefox-addToCart --project=firefox-forgotPassword --project=firefox-logout --project=firefox-removeProductFromWishlist --project=firefox-search --project=firefox-subscribeToNewsletter --project=firefox-change-password",
    "test:chrome-firefox": "npx playwright test --project=chrome-registration --project=chrome-login --project=chrome-addProductTowishlist --project=chrome-addToCart --project=chrome-forgotPassword --project=chrome-logout --project=chrome-removeProductFromWishlist --project=chrome-search --project=chrome-subscribeToNewsletter --project=chrome-change-password --project=firefox-registration --project=firefox-login --project=firefox-addProductTowishlist --project=firefox-addToCart --project=firefox-forgotPassword --project=firefox-logout --project=firefox-removeProductFromWishlist --project=firefox-search --project=firefox-subscribeToNewsletter --project=firefox-change-password",
    "test:webkit": "npx playwright test --project=webkit-registration --project=webkit-login --project=webkit-addProductTowishlist --project=webkit-addToCart --project=webkit-forgotPassword --project=webkit-logout --project=webkit-removeProductFromWishlist --project=webkit-search --project=webkit-subscribeToNewsletter --project=webkit-change-password"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.0.9",
    "allure-playwright": "^3.4.5",
    "rimraf": "^6.1.2"
  },
  "dependencies": {
    "@faker-js/faker": "^10.2.0",
    "csv-parse": "^6.1.0",
    "xlsx": "^0.18.5"
  }
}
